{% assign folder = include.folder %}
{% assign images = site.static_files | where_exp: 'file', 'file.path contains folder' %}

<div class="row" style="margin: -4px;">
  {% for image in images %}
    {% assign ext = image.extname | downcase %}
    {% if ext == '.jpg' or ext == '.jpeg' or ext == '.png' %}
      {% assign alt = image.basename | replace: '_', ' ' | replace: '-', ' ' | replace: '.MP', '' %}
      {% assign thumb = image.path | replace: ext, '' | append: '-480.webp' %}
      <div class="col-sm-4" style="padding: 4px;">
        <img
          src="{{ thumb | relative_url }}"
          data-zoom-src="{{ image.path | relative_url }}"
          class="img-fluid rounded"
          style="width:100%;height:240px;object-fit:cover;"
          data-zoomable
          loading="lazy"
          alt="{{ alt }}"
        >
      </div>
    {% endif %}
  {% endfor %}
</div>
