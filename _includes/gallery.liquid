{% assign folder = include.folder %}
{% assign images = site.static_files | where_exp: "file", "file.path contains folder" %}

<div class="row g-2">
  {% for image in images %}
    {% assign ext = image.extname | downcase | remove: "." %}
    {% if ext == "jpg" or ext == "jpeg" or ext == "png" or ext == "gif" %}
    <div class="col-sm-4">
      <img
        src="{{ image.path | relative_url }}"
        class="img-fluid rounded"
        style="width:100%;height:240px;object-fit:cover;cursor:zoom-in;"
        data-zoomable
        alt="{{ image.basename }}"
        loading="lazy"
      >
    </div>
    {% endif %}
  {% endfor %}
</div>
