{% assign person = include.person %}
<div class="row mb-4 align-items-center">
  <div class="col-sm-auto mb-2 mb-sm-0">
    <img
      src="{{ '/assets/img/people/' | append: person.img | relative_url }}"
      class="img-fluid rounded"
      style="width:110px;height:110px;object-fit:cover;"
      alt="{{ person.name }}"
      onerror="this.onerror=null;this.src='{{ '/assets/img/people/placeholder.svg' | relative_url }}'"
    >
  </div>
  <div class="col">
    <strong>{{ person.name }}</strong><br>
    <span class="text-muted">
      {{- person.role }} &middot; Joined {{ person.joined -}}
      {% if person.collaborators %} &middot; In collaboration with {{ person.collaborators }}{% endif %} </span
    ><br>
    <em>Research:</em> {{ person.research }}
    {% if person.awards %}
      <ul style="margin: 0.2rem 0 0 0; padding-left: 1.2rem;">
        {% for award in person.awards %}
          <li>{{ award }}</li>
        {% endfor %}
      </ul>
    {% endif %}
  </div>
</div>
